import tkinter as tk
from tkinter import messagebox, ttk
import time
import random
from collections import deque

# --- Lógica del Juego ---
class EightPuzzle:
    def __init__(self, initial_state):
        # Definimos el estado meta y convertimos el inicial a tupla para poder usarlo en sets/diccionarios
        self.goal = (1, 2, 3, 4, 5, 6, 7, 8, 0)
        self.initial = tuple(initial_state)

    def get_moves(self, state):
        # Esta función busca qué movimientos son válidos según la posición del espacio vacío (0)
        moves = []
        idx = state.index(0)
        row, col = divmod(idx, 3) # Convertimos el índice 0-8 a coordenadas fila/columna
        
        # Intentamos mover en las 4 direcciones
        for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:
            r, c = row + dr, col + dc
            if 0 <= r < 3 and 0 <= c < 3: # Verificamos que no se salga de la cuadrícula
                new_idx = r * 3 + c
                new_state = list(state)
                # Intercambiamos el hueco con la ficha vecina
                new_state[idx], new_state[new_idx] = new_state[new_idx], new_state[idx]
                moves.append(tuple(new_state))
        return moves

    def solve_bfs(self):
        # Implementación de Búsqueda en Amplitud: garantiza el camino más corto
        # Usamos una cola (FIFO) para explorar nivel por nivel
        queue = deque([(self.initial, [])])
        visited = {self.initial}
        
        while queue:
            state, path = queue.popleft() # Extraemos el nodo más antiguo
            if state == self.goal:
                return path + [state], len(visited)
            
            for move in self.get_moves(state):
                if move not in visited:
                    visited.add(move)
                    queue.append((move, path + [state]))
        return None, len(visited)

    def solve_dfs(self, limit=50000):
        # Implementación de Búsqueda en Profundidad: usa una pila (LIFO)
        # No garantiza el camino más corto y puede ser muy ineficiente
        stack = [(self.initial, [])]
        visited = {self.initial}
        
        while stack:
            state, path = stack.pop() # Extraemos el último nodo agregado
            if state == self.goal:
                return path + [state], len(visited)
            
            # Control de seguridad para evitar que el programa se cuelgue en estados muy profundos
            if len(visited) > limit:
                break

            for move in self.get_moves(state):
                if move not in visited:
                    visited.add(move)
                    stack.append((move, path + [state]))
        return None, len(visited)

# --- Interfaz Gráfica ---
class PuzzleApp:
    def __init__(self, root):
        self.root = root
        self.root.title("IA: BFS vs DFS - 8 Puzzle")
        
        # El 0 se interpreta como el espacio vacío
        self.estado_actual = [1, 2, 3, 4, 5, 6, 7, 8, 0]
        self.botones = []
        
        # Contenedor de botones de control (Derecha)
        control_frame = tk.Frame(root)
        control_frame.pack(side="right", padx=20)

        tk.Label(control_frame, text="Configuración", font=("Arial", 12, "bold")).pack(pady=10)
        
        self.btn_mezclar = tk.Button(control_frame, text="1. Mezclar", command=self.mezclar_puzzle, width=15)
        self.btn_mezclar.pack(pady=5)

        # Menú desplegable para elegir el algoritmo
        tk.Label(control_frame, text="Elegir Método:").pack()
        self.metodo_var = tk.StringVar(value="BFS")
        self.combo_metodo = ttk.Combobox(control_frame, textvariable=self.metodo_var, values=["BFS", "DFS"], state="readonly")
        self.combo_metodo.pack(pady=5)

        self.btn_resolver = tk.Button(control_frame, text="2. Resolver", command=self.ejecutar_animacion, bg="lightblue", width=15)
        self.btn_resolver.pack(pady=10)

        # Etiquetas para mostrar las métricas de rendimiento exigidas
        self.lbl_info = tk.Label(control_frame, text="Nodos: 0\nPasos: 0", justify="left")
        self.lbl_info.pack(pady=10)

        # Contenedor del tablero (Izquierda)
        self.tablero_frame = tk.Frame(root)
        self.tablero_frame.pack(side="left", padx=20, pady=20)
        self.crear_tablero()

    def crear_tablero(self):
        # Creamos los 9 botones que representan las fichas
        for i in range(9):
            btn = tk.Button(self.tablero_frame, text="", font=("Arial", 20, "bold"), width=4, height=2)
            btn.grid(row=i // 3, column=i % 3, padx=2, pady=2)
            self.botones.append(btn)
        self.actualizar_interfaz()

    def actualizar_interfaz(self):
        # Refrescamos el aspecto visual del tablero según la lista estado_actual
        for i in range(9):
            val = self.estado_actual[i]
            # Si es el hueco (0), lo pintamos gris; si no, mostramos el número
            self.botones[i].config(text=str(val) if val != 0 else "", 
                                   bg="#ecf0f1" if val != 0 else "#7f8c8d")

    def mezclar_puzzle(self):
        # Para asegurar que el puzzle tenga solución, empezamos desde la meta
        # y realizamos movimientos aleatorios inversos.
        self.estado_actual = [1, 2, 3, 4, 5, 6, 7, 8, 0]
        p = EightPuzzle(self.estado_actual)
        for _ in range(15): 
            self.estado_actual = list(random.choice(p.get_moves(tuple(self.estado_actual))))
        self.actualizar_interfaz()
        self.lbl_info.config(text="Nodos: 0\nPasos: 0")

    def ejecutar_animacion(self):
        # Aquí se une la lógica de búsqueda con la visualización
        puzzle = EightPuzzle(self.estado_actual)
        metodo = self.metodo_var.get()
        
        self.btn_resolver.config(state="disabled", text="Buscando...")
        self.root.update()

        # Medición de tiempo de ejecución
        start = time.perf_counter()
        if metodo == "BFS":
            camino, nodos = puzzle.solve_bfs()
        else:
            camino, nodos = puzzle.solve_dfs()
        end = time.perf_counter()

        if camino:
            # Mostramos paso a paso el camino encontrado
            for paso in camino:
                self.estado_actual = list(paso)
                self.actualizar_interfaz()
                self.root.update()
                time.sleep(0.2) # Pausa para que el ojo humano siga el movimiento
            
            # Mostramos los resultados finales de la búsqueda
            self.lbl_info.config(text=f"Nodos: {nodos}\nPasos: {len(camino)-1}\nTiempo: {end-start:.4f}s")
            messagebox.showinfo("Hecho", f"Solución encontrada con {metodo}")
        else:
            messagebox.showerror("Aviso", "No se encontró solución (Límite DFS excedido)")
        
        self.btn_resolver.config(state="normal", text="2. Resolver")

if __name__ == "__main__":
    ventana = tk.Tk()
    app = PuzzleApp(ventana)
    ventana.mainloop()
